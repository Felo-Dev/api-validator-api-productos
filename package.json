{
  "name": "ecommerce-monorepo",
  "version": "3.0.0",
  "private": true,
  "description": "E-commerce monorepo with microservices, Redis, and real product features",
  "workspaces": [
    "shared",
    "gateway",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:gateway": "npm run dev --workspace=gateway",
    "dev:auth": "npm run dev --workspace=auth-service",
    "dev:products": "npm run dev --workspace=product-service",
    "dev:orders": "npm run dev --workspace=order-service",
    "dev:notifications": "npm run dev --workspace=notification-service",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:db:init": "docker compose exec postgres psql -U postgres -d ecommerce_db -f /docker-entrypoint-initdb.d/init.sql",
    "docker:seed": "docker compose exec product-service node src/seed.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "redis": "^5.12.1"
  }
}
