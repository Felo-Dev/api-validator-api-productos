# Gateway
PORT=4000
AUTH_SERVICE_URL=http://localhost:4001
PRODUCT_SERVICE_URL=http://localhost:4002
ORDER_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4004

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL (shared)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ecommerce_db

# Product Service DB
PRODUCT_DB_HOST=localhost
PRODUCT_DB_PORT=5432
PRODUCT_DB_USER=postgres
PRODUCT_DB_PASSWORD=postgres
PRODUCT_DB_DATABASE=ecommerce_db

# Order Service DB
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5432
ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=postgres
ORDER_DB_DATABASE=ecommerce_db

# Billing Service
BILLING_SERVICE_URL=http://localhost:4005
BILLING_DB_HOST=localhost
BILLING_DB_PORT=5432
BILLING_DB_USER=postgres
BILLING_DB_PASSWORD=postgres
BILLING_DB_DATABASE=ecommerce_db

# Emisor fiscal (datos del negocio para facturación)
BILLING_EMISOR_RFC=RFC123456XYZ
BILLING_EMISOR_NOMBRE=Mi Empresa S.A. de C.V.
BILLING_EMISOR_REGIMEN=601
BILLING_EMISOR_CP=00000

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

NODE_ENV=development
